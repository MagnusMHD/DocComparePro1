<Window x:Class="DocComparePro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DocComparePro"
        Width="1600"
        Height="900"
        MinWidth="1400"
        MinHeight="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"

        Background="{StaticResource BackgroundBrush}">

    <DockPanel>

        <!-- TOP BAR -->

        <Border DockPanel.Dock="Top"
        Height="50"
        Background="#111111"
        MouseDown="TitleBar_MouseDown">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📄"
                       FontSize="20"
                       Margin="15,0,10,0"
                       VerticalAlignment="Center"/>

                    <TextBlock Text="DocComparePro"
                       FontSize="18"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

                </StackPanel>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal">

                    <Button x:Name="BtnMinimize"
                    Content="—"
                    Click="BtnMinimize_Click"
                    Width="45"
                    Height="45"/>

                    <Button x:Name="BtnMaximize"
                    Content="□"
                    Click="BtnMaximize_Click"
                    Width="45"
                    Height="45"/>

                    <Button x:Name="BtnClose"
                    Content="✕"
                    Click="BtnClose_Click"
                    Width="45"
                    Height="45"
                    Foreground="Red"/>

                </StackPanel>

            </Grid>

        </Border>
        <!-- MAIN -->

        <Grid Margin="15">

            <Grid.RowDefinitions>

                <RowDefinition Height="250"/>
                <RowDefinition Height="170"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <!-- UPLOAD -->

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition/>
                    <ColumnDefinition/>

                </Grid.ColumnDefinitions>

                <!-- DOCUMENT A -->

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Dokument A"
                                   FontSize="22"
                                   FontWeight="Bold"/>

                        <Border Height="140"
                                Margin="0,15,0,0"
                                BorderThickness="2"
                                BorderBrush="{StaticResource NeonGreenBrush}"
                                CornerRadius="15">

                            <Grid>

                                <TextBlock Text="Datei hier hineinziehen"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </Border>

                <!-- DOCUMENT B -->

                <Border Grid.Column="1"
                        Style="{StaticResource GlassCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Dokument B"
                                   FontSize="22"
                                   FontWeight="Bold"/>

                        <Border Height="140"
                                Margin="0,15,0,0"
                                BorderThickness="2"
                                BorderBrush="{StaticResource NeonOrangeBrush}"
                                CornerRadius="15">

                            <Grid>

                                <TextBlock Text="Datei hier hineinziehen"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- OPTIONS -->

            <Border Grid.Row="1"
                    Style="{StaticResource GlassCardStyle}">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <TextBlock Text="Vergleichsoptionen"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <WrapPanel Margin="0,10,0,0">

                            <CheckBox Content="Groß-/Kleinschreibung beachten"
                                      Margin="10"/>

                            <CheckBox Content="Zahlen exakt vergleichen"
                                      Margin="10"/>

                            <CheckBox Content="Satzzeichen vergleichen"
                                      Margin="10"/>

                            <CheckBox Content="Leerzeichen ignorieren"
                                      Margin="10"/>

                            <CheckBox Content="OCR aktivieren"
                                      Margin="10"/>

                        </WrapPanel>

                    </StackPanel>

                    <StackPanel Grid.Column="1">

                        <TextBlock Text="Modus"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <RadioButton Content="Wort zu Wort"
                                     Margin="0,10,0,5"
                                     IsChecked="True"/>

                        <RadioButton Content="Satz zu Satz"/>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- STATISTICS -->

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>

                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Übereinstimmung"/>
                        <TextBlock Text="0 %"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource GlassCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Unterschiede"/>
                        <TextBlock Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource GlassCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Geprüfte Wörter"/>
                        <TextBlock Text="0"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- RESULTS -->

            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition/>
                    <ColumnDefinition/>

                </Grid.ColumnDefinitions>

                <!-- RESULT A -->

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}">

                    <DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Dokument A"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <RichTextBox Margin="0,10,0,0"
                                     Background="#202020"
                                     Foreground="White"/>

                    </DockPanel>

                </Border>

                <!-- RESULT B -->

                <Border Grid.Column="1"
                        Style="{StaticResource GlassCardStyle}">

                    <DockPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Text="Dokument B"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <RichTextBox Margin="0,10,0,0"
                                     Background="#202020"
                                     Foreground="White"/>

                    </DockPanel>

                </Border>

            </Grid>

        </Grid>

        <!-- STATUSBAR -->

        <StatusBar DockPanel.Dock="Bottom">

            <StatusBarItem>

                <TextBlock Text="Bereit"/>

            </StatusBarItem>

        </StatusBar>

    </DockPanel>

    </Window>