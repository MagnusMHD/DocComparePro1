<Window x:Class="DocComparePro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DocComparePro"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="MainWindow_OnLoaded">
    <Window.Resources>
        <Style x:Key="AlignedListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource EditorBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style x:Key="AlignedItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="30" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Changed">
                    <Setter Property="Background" Value="#35FFC107" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5000D9FF" />
                    <Setter Property="BorderBrush" Value="{DynamicResource NeonBlueBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LeftAlignedItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource AlignedItemStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Removed">
                    <Setter Property="Background" Value="#35F44336" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Added">
                    <Setter Property="Opacity" Value="0.3" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5000D9FF" />
                    <Setter Property="BorderBrush" Value="{DynamicResource NeonBlueBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RightAlignedItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource AlignedItemStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Added">
                    <Setter Property="Background" Value="#3500E676" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Removed">
                    <Setter Property="Opacity" Value="0.3" />
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5000D9FF" />
                    <Setter Property="BorderBrush" Value="{DynamicResource NeonBlueBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImagePreviewBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#B0151515" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Ellipse Width="620" Height="620" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-260,-300,0,0" IsHitTestVisible="False">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="{StaticResource NeonBlueColor}" Offset="0" /><GradientStop Color="#0000D9FF" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
            <Ellipse.Opacity>0.22</Ellipse.Opacity>
        </Ellipse>
        <Ellipse Width="560" Height="560" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-220,-280" IsHitTestVisible="False">
            <Ellipse.Fill><RadialGradientBrush><GradientStop Color="{StaticResource NeonGreenColor}" Offset="0" /><GradientStop Color="#0000FFAA" Offset="1" /></RadialGradientBrush></Ellipse.Fill>
            <Ellipse.Opacity>0.17</Ellipse.Opacity>
        </Ellipse>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="4,0,4,16">
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="DocComparePro" FontSize="32" FontWeight="Bold" />
                    <TextBlock Text="Automatische Vorschau und markierter Dokumentvergleich" Margin="0,3,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Zurücksetzen" Command="{Binding ClearCommand}" Style="{StaticResource DarkButtonStyle}" />
                    <Button Content="Bericht exportieren" Command="{Binding ExportCommand}" Style="{StaticResource DarkButtonStyle}" />
                    <Button Content="Abbrechen" Command="{Binding CancelComparisonCommand}" Style="{StaticResource DarkButtonStyle}" />
                    <Button Content="Neu vergleichen" Command="{Binding CompareCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="14" /><ColumnDefinition /></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource UploadZoneStyle}" BorderBrush="{DynamicResource NeonGreenBrush}" AllowDrop="True" Drop="LeftDropZone_OnDrop">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Dokument A" FontSize="19" FontWeight="Bold" />
                            <TextBlock Text="Auswahl lädt sofort eine Vorschau" Margin="0,5,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock Text="{Binding LeftFileName}" Margin="0,12,18,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Datei auswählen" Command="{Binding SelectLeftFileCommand}" Style="{StaticResource DarkButtonStyle}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource UploadZoneStyle}" BorderBrush="{DynamicResource NeonOrangeBrush}" AllowDrop="True" Drop="RightDropZone_OnDrop">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Dokument B" FontSize="19" FontWeight="Bold" />
                            <TextBlock Text="Beide Dateien werden automatisch verglichen" Margin="0,5,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock Text="{Binding RightFileName}" Margin="0,12,18,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Datei auswählen" Command="{Binding SelectRightFileCommand}" Style="{StaticResource DarkButtonStyle}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Vergleichsoptionen" FontSize="17" FontWeight="Bold" Margin="0,0,0,8" />
                        <WrapPanel>
                            <CheckBox Content="Groß-/Kleinschreibung" IsChecked="{Binding CaseSensitive}" />
                            <CheckBox Content="Zahlen vergleichen" IsChecked="{Binding CompareNumbers}" />
                            <CheckBox Content="Satzzeichen vergleichen" IsChecked="{Binding ComparePunctuation}" />
                            <CheckBox Content="Leerzeichen normalisieren" IsChecked="{Binding IgnoreWhitespace}" />
                            <CheckBox Content="OCR für Bilder" IsChecked="{Binding EnableOcr}" />
                            <CheckBox Content="Satzweise vergleichen" IsChecked="{Binding UseSentenceMode}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}">
                    <UniformGrid Columns="4">
                        <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="Ähnlichkeit" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock Text="{Binding SimilarityPercentage, StringFormat={}{0:N2} %}" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource NeonGreenBrush}" /></StackPanel></Border>
                        <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="Unterschiede" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock Text="{Binding DifferenceCount}" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource NeonOrangeBrush}" /></StackPanel></Border>
                        <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="Einheiten" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock Text="{Binding ComparedUnitCount}" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource NeonBlueBrush}" /></StackPanel></Border>
                        <Border Style="{StaticResource StatCardStyle}"><StackPanel><TextBlock Text="Dauer" Foreground="{DynamicResource SecondaryTextBrush}" /><TextBlock Text="{Binding ProcessingTime}" FontSize="21" FontWeight="Bold" /></StackPanel></Border>
                    </UniformGrid>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="12" /><ColumnDefinition /><ColumnDefinition Width="12" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <TextBlock Text="Dokument A – Vorschau und Markierungen" FontWeight="Bold" Margin="0,0,0,10" />
                        <Border Grid.Row="1" Style="{StaticResource ImagePreviewBorderStyle}" Visibility="{Binding IsLeftImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Image Source="{Binding LeftImagePath}" MaxHeight="190" Stretch="Uniform" />
                        </Border>
                        <ListBox x:Name="LeftDocumentList"
                                 Grid.Row="2"
                                 ItemsSource="{Binding LeftPreviewItems}"
                                 SelectedItem="{Binding SelectedDifference, Mode=TwoWay}"
                                 Style="{StaticResource AlignedListStyle}"
                                 ItemContainerStyle="{StaticResource LeftAlignedItemStyle}">
                            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding LeftText}" FontFamily="Consolas" TextWrapping="Wrap" /></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <TextBlock Text="Dokument B – Vorschau und Markierungen" FontWeight="Bold" Margin="0,0,0,10" />
                        <Border Grid.Row="1" Style="{StaticResource ImagePreviewBorderStyle}" Visibility="{Binding IsRightImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Image Source="{Binding RightImagePath}" MaxHeight="190" Stretch="Uniform" />
                        </Border>
                        <ListBox x:Name="RightDocumentList"
                                 Grid.Row="2"
                                 ItemsSource="{Binding RightPreviewItems}"
                                 SelectedItem="{Binding SelectedDifference, Mode=TwoWay}"
                                 Style="{StaticResource AlignedListStyle}"
                                 ItemContainerStyle="{StaticResource RightAlignedItemStyle}">
                            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding RightText}" FontFamily="Consolas" TextWrapping="Wrap" /></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource GlassCardStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Gefundene Unterschiede" FontWeight="Bold" Margin="0,0,0,10" />
                        <DataGrid ItemsSource="{Binding Differences}"
                                  SelectedItem="{Binding SelectedDifference, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  AlternationCount="2"
                                  Style="{StaticResource DifferenceDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="48" />
                                <DataGridTextColumn Header="Typ" Binding="{Binding Kind}" Width="88" />
                                <DataGridTextColumn Header="Dokument A" Binding="{Binding LeftText}" Width="*" />
                                <DataGridTextColumn Header="Dokument B" Binding="{Binding RightText}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4" Margin="4,13,4,0">
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="280" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ComparisonProgress}" Height="8" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Grid>
</Window>
