<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- FadeIn -->

    <Storyboard x:Key="FadeIn">

        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0"
            To="1"
            Duration="0:0:0.3"/>

    </Storyboard>

    <!-- Button Hover -->

    <Storyboard x:Key="ButtonHover">

        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            To="0.85"
            Duration="0:0:0.15"/>

    </Storyboard>

</ResourceDictionary>